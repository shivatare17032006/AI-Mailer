# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/superbfsi_campaigns
# For MongoDB Atlas, use: mongodb+srv://<username>:<password>@cluster.mongodb.net/superbfsi_campaigns

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4

# SendGrid Email API (Optional - can use mock for development)
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
FROM_EMAIL=campaigns@superbfsi.com

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Email Mode (mock or live)
EMAIL_MODE=mock
# Set to 'live' when using real SendGrid API

# Analytics Configuration
ANALYTICS_UPDATE_INTERVAL=60000
# Interval in ms to check for analytics updates (default: 60 seconds)
